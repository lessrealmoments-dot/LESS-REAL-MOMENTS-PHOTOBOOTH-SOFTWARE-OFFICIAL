<UserControl x:Class="BoothDesktop.Views.EventsView"
             x:Name="EventsRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1400"
             Background="{StaticResource Brush.WindowBg}">
    <Grid Margin="48">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Booth" FontSize="42" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"/>
            <TextBlock Text="Events" FontSize="20" Foreground="{StaticResource Brush.TextMuted}" Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="0" Margin="0,86,0,0" Padding="14,10" CornerRadius="12"
                Background="{StaticResource Brush.Card}" BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="CameraStatusDot" Width="10" Height="10" Fill="#FFC0902A" Margin="0,0,10,0"/>
                        <TextBlock x:Name="CameraStatusTitle" Text="Camera: checking..." FontSize="15"
                                   Foreground="{StaticResource Brush.Text}" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CameraStatusDetail" Margin="10,0,0,0"
                                   Text="bridge probe in progress" FontSize="13"
                                   Foreground="{StaticResource Brush.TextMuted}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Refresh" Style="{StaticResource Style.GhostButton}" MinWidth="96"
                                Click="OnRefreshCameraClick"/>
                        <Button Content="Reconnect" Style="{StaticResource Style.GhostButton}" MinWidth="106" Margin="10,0,0,0"
                                Click="OnReconnectCameraClick"/>
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="CameraNotReadyWarning" Grid.Row="1" Visibility="Collapsed"
                           Margin="0,10,0,0"
                           Text="Wait for the camera to connect before opening the photobooth."
                           FontSize="14" Foreground="#FFE8B84A" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="EventsList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="320" MinHeight="248" Margin="0,0,24,24" CornerRadius="20"
                                Background="{StaticResource Brush.Card}" BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.35" Color="#000000"/>
                            </Border.Effect>
                            <Grid Margin="24">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Text}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Foreground="{StaticResource Brush.TextMuted}" FontSize="14" Margin="0,8,0,0">
                                        <TextBlock.Text>
                                            <Binding Path="CreatedUtc" StringFormat="{}{0:MMM d, yyyy}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                                    <Button Content="Open photobooth" Style="{StaticResource Style.PrimaryButton}"
                                            HorizontalAlignment="Stretch" Click="OnOpenBoothClick" Tag="{Binding}"
                                            IsEnabled="{Binding IsCameraReady, ElementName=EventsRoot}"/>
                                    <Button Content="Layouts for this event…" Style="{StaticResource Style.GhostButton}"
                                            HorizontalAlignment="Stretch" Margin="0,10,0,0" FontSize="13"
                                            Click="OnEventLayoutsClick" Tag="{Binding}"/>
                                    <Button Content="Event settings…" Style="{StaticResource Style.GhostButton}"
                                            HorizontalAlignment="Stretch" Margin="0,10,0,0" FontSize="13"
                                            Click="OnEventSettingsClick" Tag="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="New event" Style="{StaticResource Style.GhostButton}" Margin="0,0,16,0" Click="OnNewEventClick"/>
            <Button Content="Import layout (ZIP)…" Style="{StaticResource Style.GhostButton}" Margin="0,0,16,0" Click="OnImportLayoutClick"/>
            <Button Content="Global settings…" Style="{StaticResource Style.GhostButton}" Margin="0,0,16,0" Click="OnGlobalSettingsClick"/>
            <Button Content="Duplicate settings…" Style="{StaticResource Style.GhostButton}" Opacity="0.5" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</UserControl>
