<Window x:Class="BoothDesktop.Views.GlobalSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Global settings"
        Width="640" Height="420"
        MinWidth="560" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.WindowBg}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Global settings" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text}"/>
            <TextBlock Margin="0,6,0,0" FontSize="14" Foreground="{StaticResource Brush.TextMuted}"
                       TextWrapping="Wrap"
                       Text="Set the default printer and where booth files are saved (events, originals, prints, logs)."/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <TextBlock Text="Storage location" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"/>
            <TextBlock Margin="0,6,0,10" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap"
                       Text="Choose the root folder for LessRealBooth data. This folder contains events/, catalog/, logs/."/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="StorageRootText"
                         Height="34"
                         Padding="10,6"
                         VerticalContentAlignment="Center"
                         Background="{StaticResource Brush.Card}"
                         Foreground="{StaticResource Brush.Text}"
                         BorderBrush="{StaticResource Brush.Stroke}"
                         BorderThickness="1"/>
                <Button Grid.Column="1" Content="Browse…" Style="{StaticResource Style.GhostButton}" Margin="10,0,0,0"
                        MinWidth="110" Click="OnBrowseStorageClick"/>
                <Button Grid.Column="2" Content="Default" Style="{StaticResource Style.GhostButton}" Margin="10,0,0,0"
                        MinWidth="90" Click="OnUseDefaultStorageClick"/>
            </Grid>

            <TextBlock x:Name="StorageHintText" Margin="0,8,0,0" FontSize="12" FontFamily="Consolas"
                       Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap"/>

            <Border Height="1" Background="{StaticResource Brush.Stroke}" Margin="0,24,0,20"/>

            <TextBlock Text="Default printer" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"/>
            <TextBlock Margin="0,6,0,10" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap"
                       Text="Select your preferred printer (used by print actions). Keep '(System default)' to follow Windows default printer."/>
            <ComboBox x:Name="PrinterCombo"
                      Height="34"
                      Padding="8,4"
                      Background="{StaticResource Brush.Card}"
                      Foreground="{StaticResource Brush.Text}"
                      BorderBrush="{StaticResource Brush.Stroke}"
                      BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Style="{StaticResource Style.GhostButton}" MinWidth="100" Margin="0,0,12,0"
                    IsCancel="True" Click="OnCancelClick"/>
            <Button Content="Save" Style="{StaticResource Style.PrimaryButton}" MinWidth="100"
                    IsDefault="True" Click="OnSaveClick"/>
        </StackPanel>
    </Grid>
</Window>
