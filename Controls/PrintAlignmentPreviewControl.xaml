<UserControl x:Class="BoothDesktop.Controls.PrintAlignmentPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="360" d:DesignWidth="400">
    <Border Background="{StaticResource Brush.Card}" BorderBrush="{StaticResource Brush.Stroke}"
            BorderThickness="1" CornerRadius="10" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock x:Name="SummaryLine" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Text}" TextWrapping="Wrap"/>
                <TextBlock x:Name="DetailLine" Margin="0,4,0,0" FontSize="12"
                           Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap"/>
            </StackPanel>

            <Viewbox Grid.Row="1" Stretch="Uniform" MaxHeight="260" HorizontalAlignment="Center">
                <Canvas x:Name="PaperCanvas" Width="420" Height="620" ClipToBounds="True">
                    <!-- Paper + print rect drawn in code-behind -->
                </Canvas>
            </Viewbox>

            <TextBlock Grid.Row="2" Margin="0,10,0,0" FontSize="11" TextWrapping="Wrap"
                       Foreground="{StaticResource Brush.TextMuted}" TextAlignment="Center"
                       Text="Gold outline = print on paper. Gray = empty paper. Moves match the printer: +Horizontal ? right, +Vertical ? down."/>
        </Grid>
    </Border>
</UserControl>
